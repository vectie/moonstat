      "providerId": "anthropic",
      "providerName": "Anthropic",
      "requestCount": 1,
      "totalTokens": 55,
      "totalCost": "0.000200",
      "successRate": 0,
      "avgLatencyMs": 70,
    },
    {
      "providerId": "codex-oauth",
      "providerName": "Codex OAuth",
      "requestCount": 1,
      "totalTokens": 70,
      "totalCost": "0.000100",
      "successRate": 100,
      "avgLatencyMs": 30,
    },
  ])
  json_inspect(stats.model_stats_json(), content=[
    {
