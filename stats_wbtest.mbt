        "totalCost": "0.000200",
        "totalInputTokens": 50,
        "totalOutputTokens": 5,
        "totalCacheCreationTokens": 10,
        "totalCacheReadTokens": 20,
        "successRate": 0,
        "realTotalTokens": 85,
        "cacheHitRate": 0.25,
