  json_inspect(stats.usage_data_sources_json(), content=[
    { "dataSource": "proxy", "requestCount": 1, "totalCostUsd": "0.000100" },
    { "dataSource": "session", "requestCount": 1, "totalCostUsd": "0.000200" },
