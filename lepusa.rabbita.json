{
  "identifier": "dev.vectie.moonstat.rabbita",
  "productName": "Moonstat Rabbita Preview",
  "version": "0.1.0",
  "rootHtml": "<link href=\"/assets/moonstat.css\" rel=\"stylesheet\"><div data-moonstat-api-base=\"http://127.0.0.1:15721\" class=\"shell\"><aside aria-label=\"Moonstat navigation\" class=\"sidebar\"><div class=\"brand\"><span aria-hidden=\"true\" class=\"mark\">M</span><div><strong>Moonstat</strong><span>Lepusa Rabbita shell</span></div></div><nav class=\"nav\"><a href=\"#overview\" target=\"_self\">Overview</a><a href=\"#providers\" target=\"_self\">Providers</a><a href=\"#frameworks\" target=\"_self\">Frameworks</a><a href=\"#setup\" target=\"_self\">Setup</a><a href=\"#suite\" target=\"_self\">Suite</a><a href=\"#resilience\" target=\"_self\">Resilience</a><a href=\"#usage\" target=\"_self\">Usage</a><a href=\"#usage-explorer\" target=\"_self\">Explorer</a><a href=\"#requests\" target=\"_self\">Requests</a></nav><div class=\"sidebar-footer\"><span id=\"ui-updated\">Waiting for data</span></div></aside><main class=\"main\"><section class=\"topbar\" id=\"overview\"><div><p class=\"eyebrow\">Operator Console</p><h1>Proxy, providers, and spend in one place.</h1></div><div class=\"actions\"><button type=\"button\" id=\"refresh\">Refresh</button><button type=\"button\" id=\"proxy-start\">Start Proxy</button><button type=\"button\" class=\"danger\" id=\"proxy-stop\">Stop Proxy</button><a href=\"/metrics\" target=\"_self\" rel=\"noreferrer\" class=\"button-secondary\">Metrics</a></div></section><section class=\"status-grid\"><article class=\"metric-card\"><span>Gateway</span><strong id=\"gateway-state\">-</strong><small id=\"gateway-detail\">Loading status</small></article><article class=\"metric-card\"><span>Proxy</span><strong id=\"proxy-state\">-</strong><small id=\"proxy-detail\">Loading proxy</small></article><article class=\"metric-card\"><span>Requests</span><strong id=\"request-total\">-</strong><small id=\"request-total-detail\">Across all apps</small></article><article class=\"metric-card\"><span>Spend</span><strong id=\"cost-total\">-</strong><small id=\"cost-detail\">Estimated total</small></article></section><section class=\"panel-grid\"><article class=\"panel wide\" id=\"frameworks\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Frameworks</p><h2>Provider Control</h2></div><button type=\"button\" class=\"button-secondary\" id=\"sync-live\">Sync Live</button></div><div class=\"table-wrap\"><table><thead><tr><th>Framework</th><th>Mode</th><th>Current</th><th>Providers</th><th>Action</th></tr></thead><tbody id=\"framework-rows\"></tbody></table></div></article><article class=\"panel wide\" id=\"provider-editor\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Providers</p><h2>Provider Editor</h2></div><button type=\"button\" class=\"button-secondary\" id=\"provider-clear\">New Provider</button></div><form class=\"form-grid\" id=\"provider-form\"><input type=\"hidden\" autocomplete=\"off\" id=\"provider-original-id\"><label><span>Framework</span><select id=\"provider-app\"></select></label><label><span>Provider ID</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-id\" required></label><label><span>Name</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-name\" required></label><label><span>Provider Type</span><input type=\"text\" autocomplete=\"off\" placeholder=\"openrouter, codex_oauth, gemini\" id=\"provider-type\"></label><label class=\"span-2\"><span>Base URL</span><input type=\"text\" autocomplete=\"off\" placeholder=\"https://api.example.com\" id=\"provider-base-url\"></label><label><span>API Format</span><select id=\"provider-api-format\"><option value=\"\">Default</option><option value=\"openai\">OpenAI</option><option value=\"anthropic\">Anthropic</option><option value=\"gemini_native\">Gemini Native</option></select></label><label><span>API Key</span><input type=\"password\" autocomplete=\"off\" id=\"provider-api-key\"></label><label><span>Default Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-default-model\"></label><label><span>Sonnet Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-sonnet-model\"></label><label><span>Haiku Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-haiku-model\"></label><label><span>Opus Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"provider-opus-model\"></label><label class=\"span-2\"><span>Notes</span><textarea rows=\"3\" id=\"provider-notes\"></textarea></label><div class=\"check-row span-2\"><label><input type=\"checkbox\" autocomplete=\"off\" id=\"provider-enabled\" checked> Enabled</label><label><input type=\"checkbox\" autocomplete=\"off\" id=\"provider-full-url\"> Full URL</label><label><input type=\"checkbox\" autocomplete=\"off\" id=\"provider-fast-mode\"> Codex Fast Mode</label></div><div class=\"form-actions span-2\"><button type=\"submit\" id=\"provider-save\">Save Provider</button><button type=\"button\" class=\"danger\" id=\"provider-delete\">Delete Provider</button><button type=\"button\" class=\"button-secondary\" id=\"provider-test\">Test Provider</button><span id=\"provider-form-status\"></span></div></form></article><article class=\"panel wide\" id=\"setup\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Setup</p><h2>Integration Status</h2></div><div class=\"inline-actions\"><button type=\"button\" class=\"button-secondary\" id=\"setup-refresh\">Refresh Setup</button><button type=\"button\" class=\"button-secondary\" id=\"setup-import-mcp\">Import MCP Apps</button></div></div><div class=\"setup-grid\"><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Auth</strong><span class=\"state warn\" id=\"setup-auth-state\">Loading</span></div><div class=\"setup-list\" id=\"setup-auth-rows\"></div></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Runtime</strong><span class=\"state warn\" id=\"setup-runtime-state\">Loading</span></div><div class=\"setup-list\" id=\"setup-runtime-rows\"></div></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Claude Desktop</strong><span class=\"state warn\" id=\"setup-desktop-state\">Loading</span></div><div class=\"setup-list\" id=\"setup-desktop-rows\"></div><div class=\"inline-actions\"><button type=\"button\" id=\"setup-import-claude-desktop\">Import Claude Desktop</button></div></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>MCP and Plugin</strong><span class=\"state warn\" id=\"setup-mcp-state\">Loading</span></div><div class=\"setup-list\" id=\"setup-mcp-rows\"></div></div></div><div class=\"table-wrap setup-table-wrap\"><table><thead><tr><th>Framework</th><th>Config</th><th>Proxy Takeover</th><th>Action</th></tr></thead><tbody id=\"setup-config-rows\"></tbody></table></div></article><article class=\"panel wide\" id=\"suite\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Suite</p><h2>Moon Suite Integration</h2></div><div class=\"inline-actions\"><button type=\"button\" class=\"button-secondary\" id=\"suite-refresh\">Refresh Suite</button><button type=\"button\" id=\"suite-write-status\">Write Status</button><button type=\"button\" class=\"button-secondary\" id=\"suite-write-moonclaw\">Write MoonClaw</button></div></div><div class=\"usage-metrics\"><div><span>Status</span><strong id=\"suite-status-state\">-</strong></div><div><span>Apps</span><strong id=\"suite-app-count\">-</strong></div><div><span>Capabilities</span><strong id=\"suite-capability-count\">-</strong></div><div><span>Status File</span><strong id=\"suite-status-path\">-</strong></div></div><div class=\"table-wrap\"><table><thead><tr><th>App</th><th>Role</th><th>Usage</th><th>Key Route</th></tr></thead><tbody id=\"suite-app-rows\"></tbody></table></div><div class=\"stack\" id=\"suite-integrations\"></div></article><article class=\"panel wide\" id=\"resilience\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Routing</p><h2>Resilience Control</h2></div><div class=\"filter-row\"><select aria-label=\"Resilience framework\" id=\"resilience-app\"></select><select aria-label=\"Resilience provider\" id=\"resilience-provider\"></select><button type=\"button\" class=\"button-secondary\" id=\"resilience-refresh\">Refresh</button></div></div><div class=\"usage-metrics\"><div><span>Auto Failover</span><strong id=\"resilience-auto-state\">-</strong></div><div><span>Circuit</span><strong id=\"resilience-circuit-state\">-</strong></div><div><span>Queue</span><strong id=\"resilience-queue-count\">-</strong></div><div><span>Limits</span><strong id=\"resilience-limit-state\">-</strong></div></div><div class=\"resilience-grid\"><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Circuit Breaker</strong><span class=\"state warn\" id=\"resilience-circuit-status\">Loading</span></div><form class=\"compact-form\" id=\"circuit-form\"><label><span>Failure Threshold</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-failure-threshold\"></label><label><span>Success Threshold</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-success-threshold\"></label><label><span>Timeout Seconds</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-timeout-seconds\"></label><label><span>Error Rate</span><input inputmode=\"decimal\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-error-rate-threshold\"></label><label><span>Min Requests</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"circuit-min-requests\"></label><div class=\"inline-actions\"><button type=\"submit\">Save Circuit</button><button type=\"button\" class=\"button-secondary\" id=\"resilience-reset-circuit\">Reset Selected</button></div></form></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Stream Check</strong><span class=\"state warn\" id=\"resilience-stream-status\">Loading</span></div><form class=\"compact-form\" id=\"stream-form\"><label><span>Timeout Seconds</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-timeout-secs\"></label><label><span>Max Retries</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-max-retries\"></label><label><span>Degraded MS</span><input inputmode=\"numeric\" type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-degraded-threshold-ms\"></label><label><span>Codex Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-codex-model\"></label><label><span>Claude Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-claude-model\"></label><label><span>Gemini Model</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-gemini-model\"></label><label class=\"span-2\"><span>Prompt</span><input type=\"text\" autocomplete=\"off\" placeholder=\"\" id=\"stream-test-prompt\"></label><div class=\"inline-actions span-2\"><button type=\"submit\">Save Stream</button><button type=\"button\" class=\"button-secondary\" id=\"resilience-stream-check\">Check App</button></div></form></div></div><div class=\"resilience-grid\"><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Failover Queue</strong><button type=\"button\" class=\"button-secondary\" id=\"resilience-toggle-auto\">Toggle Auto</button></div><div class=\"stack\" id=\"failover-queue\"></div></div><div class=\"setup-card\"><div class=\"setup-card-head\"><strong>Available Providers</strong><button type=\"button\" class=\"button-secondary\" id=\"resilience-add-selected\">Add Selected</button></div><div class=\"stack\" id=\"available-failover\"></div></div></div><div class=\"log-list\" id=\"stream-check-results\"></div></article><article class=\"panel wide\" id=\"providers\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Routing</p><h2>Provider Health</h2></div><span class=\"pill\" id=\"provider-count\">0 providers</span></div><div class=\"table-wrap\"><table><thead><tr><th>Provider</th><th>App</th><th>Status</th><th>Model</th><th>Last Error</th></tr></thead><tbody id=\"provider-rows\"></tbody></table></div></article><article class=\"panel\" id=\"usage\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Usage</p><h2>By App</h2></div></div><div class=\"stack\" id=\"app-usage\"></div></article><article class=\"panel\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Models</p><h2>Top Models</h2></div></div><div class=\"stack\" id=\"model-usage\"></div></article><article class=\"panel wide\" id=\"usage-explorer\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Statistics</p><h2>Usage Explorer</h2></div><div class=\"filter-row\"><select aria-label=\"Usage framework\" id=\"usage-app\"></select><select aria-label=\"Usage range\" id=\"usage-range\"><option value=\"86400\">24 hours</option><option value=\"604800\" selected>7 days</option><option value=\"2592000\">30 days</option><option value=\"all\">All time</option></select><button type=\"button\" class=\"button-secondary\" id=\"usage-apply\">Apply</button></div></div><div class=\"usage-metrics\"><div><span>Requests</span><strong id=\"usage-filter-requests\">-</strong></div><div><span>Cost</span><strong id=\"usage-filter-cost\">-</strong></div><div><span>Tokens</span><strong id=\"usage-filter-tokens\">-</strong></div><div><span>Cache Hit</span><strong id=\"usage-filter-cache\">-</strong></div></div><div class=\"trend-bars\" id=\"usage-trends\"></div></article><article class=\"panel\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Providers</p><h2>Provider Usage</h2></div></div><div class=\"stack\" id=\"provider-usage\"></div></article><article class=\"panel\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Models</p><h2>Model Usage</h2></div></div><div class=\"stack\" id=\"filtered-model-usage\"></div></article><article class=\"panel wide\" id=\"requests\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Recent</p><h2>Request Log</h2></div><a href=\"/usage/logs\" target=\"_self\" rel=\"noreferrer\" class=\"text-link\">JSON</a></div><div class=\"log-list\" id=\"request-log\"></div></article><article class=\"panel wide\" id=\"request-detail-panel\"><div class=\"panel-head\"><div><p class=\"eyebrow\">Request</p><h2>Request Detail</h2></div><span class=\"pill\" id=\"request-detail-id\">No selection</span></div><div class=\"detail-grid\" id=\"request-detail\"></div></article></section><section class=\"error-box\" id=\"error-box\" hidden><strong>Data refresh failed</strong><p id=\"error-message\"></p></section></main></div><script src=\"/assets/moonstat-core.js\"></script><script src=\"/assets/moonstat.js\"></script>",
  "runtime": {
    "backend": "system-webview",
    "assetProtocol": "lepusa",
    "devtools": false
  },
  "window": {
    "label": "main",
    "title": "Moonstat",
    "width": 1180,
    "height": 780,
    "resizable": true
  },
  "plugins": [
    {
      "name": "localhost"
    },
    {
      "name": "serviceDiscovery"
    },
    {
      "name": "opener"
    }
  ],
  "capabilities": [
    {
      "name": "main",
      "windows": [
        "main"
      ],
      "permissions": [
        "localhost",
        "service-discovery",
        "opener"
      ]
    }
  ],
  "startup": {
    "effect": "connect-moonstat-rabbita-preview"
  }
}
